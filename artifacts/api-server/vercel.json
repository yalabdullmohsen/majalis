{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "echo 'api-server artifact is served outside this Vercel project; skipping Vercel rebuild' && exit 0",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @workspace/api-server run build",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    }
  ]
}
