عند كثير من أهل العلم.\n\n**الشروط:**\n- أن تكون الكلمات حسنة.\n- ألا تشتمل على آلات موسيقية.\n- ألا تُلهي عن ذكر الله أو الصلاة.","category":"طلب العلم والدعوة","subcategory":"آداب الفتوى","subcategories":["آداب الفتوى"],"quran_evidence":[],"sunnah_evidence":[],"scholar_opinions":[],"evidence":[],"references":[{"text":"ابن عثيمين رحمه الله","source":"فتوى معتمدة"}],"keywords":["أناشيد","موسيقى","استماع"],"benefits":[],"importance_score":75,"popularity_score":2800,"view_count":2800,"search_count":650,"status":"approved","verification_status":"approved","source_origin":"fatwa-seed","linked_qa_ids":[],"linked_fatwa_ids":["fatwa-music-voice"],"linked_fiqh_ids":[],"published_at":"2026-06-27T14:32:59.420Z","created_at":"2026-06-27T14:32:59.420Z","updated_at":"2026-06-27T14:32:59.420Z"},{"id":"fatwa-ruling-fatwa-fasting-travel","external_key":"fatwa-ruling-fatwa-fasting-travel","title":"هل يجوز للمسافر الإفطار في رمضان؟","summary":"يجوز للمسافر الإفطار في رمضان مع وجوب القضاء.","body":"نعم، يجوز للمسافر الإفطار في رمضان، ويُستحب له الإفطار تيسيراً على نفسه.\n\n**الدليل:** قوله تعالى: «فَمَنْ كَانَ مِنْكُمْ مَرِيضًا أَوْ عَلَى سَفَرٍ فَعِدَّةٌ مِنْ أَيَّامٍ أُخَرَ».\n\nيجب عليه قضاء ما أفطر من أيام.","category":"طلب العلم والدعوة","subcategory":"آداب الفتوى","subcategories":["آداب الفتوى"],"quran_evidence":[],"sunnah_evidence":[],"scholar_opinions":[],"evidence":[],"references":[{"text":"اللجنة الدائمة","source":"فتوى معتمدة"}],"keywords":["صيام","سفر","إفطار","رمضان"],"benefits":[],"importance_score":75,"popularity_score":5100,"view_count":5100,"search_count":1100,"status":"approved","verification_status":"approved","source_origin":"fatwa-seed","linked_qa_ids":[],"linked_fatwa_ids":["fatwa-fasting-travel"],"linked_fiqh_ids":[],"published_at":"2026-06-27T14:32:59.420Z","created_at":"2026-06-27T14:32:59.420Z","updated_at":"2026-06-27T14:32:59.420Z"}]