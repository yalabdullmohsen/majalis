ance_score":50,"popularity_score":123,"view_count":123,"search_count":0,"status":"approved","verification_status":"approved","source_origin":"qa-seed","linked_qa_ids":["seed-qa-179"],"linked_fatwa_ids":[],"linked_fiqh_ids":[],"published_at":"2026-07-13T06:43:59.075Z","created_at":"2026-07-13T06:43:59.075Z","updated_at":"2026-07-13T06:43:59.075Z"},{"id":"qa-ruling-seed-qa-180","external_key":"qa-ruling-seed-qa-180","title":"دليل اليوم الآخر؟","summary":"قوله تعالى: ﴿يَوْمَ تَجِدُ كُلُّ نَفْسٍ مَّا عَمِلَتْ مِنْ خَيْرٍ مُّحْضَرًا﴾، والأحاديث المتواترة عن أهوال يوم القيامة.","body":"**السؤال:** ما دليل اليوم الآخر؟\n\n**الجواب:** قوله تعالى: ﴿يَوْمَ تَجِدُ كُلُّ نَفْسٍ مَّا عَمِلَتْ مِنْ خَيْرٍ مُّحْضَرًا﴾، والأحاديث المتواترة عن أهوال يوم القيامة.","category":"العقيدة","subcategory":"الإيمان","subcategories":["الإيمان"],"quran_evidence":[],"sunnah_evidence":[],"scholar_opinions":[],"evidence":[{"text":"مجالس العلم — الأسئلة والأجوبة","source":"qa-seed"}],"references":[{"text":"مجالس العلم — الأسئلة والأجوبة","source":"qa-seed"}],"keywords":["الإيمان","aqeedah","العقيدة"],"benefits":[],"importance_score":50,"popularity_score":314,"view_count":314,"search_count":0,"status":"approved","verification_status":"approved","source_origin":"qa-seed","linked_qa_ids":["seed-qa-180"],"linked_fatwa_ids":[],"linked_fiqh_ids":[],"published_at":"2026-07-13T06:43:59.075Z","created_at":"2026-07-13T06:43:59.075Z","updated_at":"2026-07-13T06:43:59.075Z"},{"id":"qa-ruling-seed-qa-181","external_key":"qa-ruling-seed-qa-181","title":"معنى الولاء والبراء؟","summary":"محبة المؤمنين ونصرتهم (الولاء)، وبغض الشرك وأهله وترك موالاتهم على حساب الدين (البراء). وهو أصل من أصول العقيدة.","body":"**السؤال:** ما معنى الولاء والبراء؟\n\n**الجواب:** محبة المؤمنين ونصرتهم (الولاء)، وبغض الشرك وأهله وترك موالاتهم على حساب الدين (البراء). وهو أصل من أصول العقيدة.","category":"العقيدة","subcategory":"الإيمان","subcategories":["الإيمان"],"quran_evidence":[],"sunnah_evidence":[],"scholar_opinions":[],"evidence"