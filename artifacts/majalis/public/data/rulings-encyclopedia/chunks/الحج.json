dence":[],"scholar_opinions":[],"evidence":[{"type":"قرآن","text":"فَمَن كَانَ مِنكُم مَّرِيضًا أَوْ بِهِ أَذًى مِّن رَّأْسِهِ فَفِدْيَةٌ مِّن صِيَامٍ أَوْ صَدَقَةٍ أَوْ نُسُكٍ","source":"البقرة: 196"},{"type":"حديث","text":"لا يَنكِحُ المُحرِمُ ولا يُنكَح ولا يَخطُب","source":"رواه مسلم"}],"references":[{"text":"المغني — ابن قدامة","source":"كتاب الحج، باب محظورات الإحرام"},{"text":"الشرح الممتع — ابن عثيمين","source":"كتاب الحج"}],"keywords":["إحرام","محظورات","فدية","حج","صيد","طيب","مخيط"],"benefits":[],"importance_score":80,"popularity_score":3100,"view_count":3100,"search_count":0,"status":"approved","verification_status":"approved","source_origin":"rulings-seed","linked_qa_ids":[],"linked_fatwa_ids":[],"linked_fiqh_ids":[],"published_at":"2024-11-15T08:00:00Z","created_at":"2024-11-15T08:00:00Z","updated_at":"2026-07-13T15:47:35.654Z"},{"id":"ruling-hajj-debt","external_key":"ruling-hajj-debt","title":"حكم الحج على المديون","summary":"هل يجب الحج على من عليه ديون؟","body":"**المسألة:**\nمن عليه ديون، هل يلزمه الحج قبل سداد ديونه؟\n\n**الحكم الراجح:**\nلا يجب الحج على من كانت ديونه تستغرق ما لديه من المال المُعدّ للحج، أو كانت حالّة يطالبه بها الدائنون.\n\n**التفصيل:**\n1. **الديون الحالّة المطالَب بها:** لا يجوز الحج قبل سدادها، لأن الحج فرض على المستطيع والمديون ليس مستطيعاً.\n2. **الديون المؤجلة (بتراضٍ):** إن أذن الدائن بالحج صحّ، وإلا فالأولى تأخيره.\n3. **دين المضمون (كالراتب المؤجل):** إن ثقة بالسداد وأذن الدائن جاز.\n\n**قاعدة جامعة:**\nحق الآدمي مقدّم على حق الله تعالى لأن الله يقبل التوبة ويعفو، والآدمي لا يملك العفو عن حقه إلا باختياره.\n\n**النصيحة العملية:**\nتفاهم مع دائنيك وأخّر الحج حتى تسدد، أو خذ إذنهم قبل الحج.","category":"الحج","subcategories":[],"quran_evidence":[],"sunnah_evidence":[],"scholar_opinions":[],"evidence":[{"type":"قرآن","text":"وَلِلَّهِ عَلَى النَّاسِ حِجُّ الْبَيْتِ مَنِ اسْتَطَاعَ إِلَيْهِ سَبِيلاً","source":"آل عمران: 97"},{"type":"قاعدة فقهية","text":"حقوق الآدميين مقدّمة لحاجتهم وتضررهم","source":"القواعد الفقهية"}],"references":[{"text":"المجموع شرح المهذب — النووي","source":"كتاب الحج"},{"text":"الشرح الممتع — ابن عثيمين","source":"كتاب الحج"}],"keywords":["حج","دين","استطاعة","مديون","سداد"],"benefits":[],"importance_score":85,"popularity_score":4300,"view_count":4300,"search_count":0,"status":"approved","verification_status":"approved","source_origin":"rulings-seed","linked_qa_ids":[],"linked_fatwa_ids":[],"linked_fiqh_ids":[],"published_at":"2025-04-01T08:00:00Z","created_at":"2025-04-01T08:00:00Z","updated_at":"2026-07-13T15:47:35.654Z"},{"id":"ruling-hajj-debt-part-1","external_key":"ruling-hajj-debt-part-1","title":"حكم الحج على المديون: **الديون الحالّة المطالَب بها:** لا يجوز الحج قبل سدادها، لأ","summary":"**الديون الحالّة المطالَب بها:** لا يجوز الحج قبل سدادها، لأن الحج فرض على المستطيع والمديون ليس مستطيعاً.","body":"**الديون الحالّة المطالَب بها:** لا يجوز الحج قبل سدادها، لأن الحج فرض على المستطيع والمديون ليس مستطيعاً.\n\n**من:** حكم الحج على المديون","category":"الحج","subcategories":[],"quran_evidence":[],"sunnah_evidence":[],"scholar_opinions":[],"evidence":[{"type":"قرآن","text":"وَلِلَّهِ عَلَى النَّاسِ حِجُّ الْبَيْتِ مَنِ اسْتَطَاعَ إِلَيْهِ سَبِيلاً","source":"آل عمران: 97"},{"type":"قاعدة فقهية","text":"حقوق الآدميين مقدّمة لحاجتهم وتضررهم","source":"القواعد الفقهية"}],"references":[{"text":"المجموع شرح المهذب — النووي","source":"كتاب الحج"},{"text":"الشرح الممتع — ابن عثيمين","source":"كتاب الحج"}],"keywords":["حج","دين","استطاعة","مديون","سداد"],"benefits":[],"importance_score":80,"popularity_score":4300,"view_count":4300,"search_count":0,"status":"approved","verification_status":"approved","source_origin":"rulings-seed","linked_qa_ids":[],"linked_fatwa_ids":[],"linked_fiqh_ids":[],"published_at":"2025-04-01T08:00:00Z","created_at":"2025-04-01T08:00:00Z","updated_at":"2026-07-13T15:47:35.654Z"},{"id":"ruling-hajj-debt-part-2","external_key":"ruling-hajj-debt-part-2","title":"حكم الحج على المديون: **الديون المؤجلة (بتراضٍ):** إن أذن الدائن بالحج صحّ، وإ