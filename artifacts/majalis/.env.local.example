# ── المجلس العلمي — متغيرات البيئة (Vite + Express) ──
# انسخ إلى .env.local واملأ القيم الفعلية

# Supabase (عام — يُستخدم في المتصفح)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Supabase (خادم فقط — لا تضف VITE_ لهذا المفتاح)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_URL=https://your-project.supabase.co

# Postgres Transaction Pooler — REQUIRED on Vercel (direct db.*.supabase.co is IPv6-only)
# Copy the exact "Transaction pooler" string from Supabase Dashboard → Project Settings → Database
# User MUST be postgres.[project-ref] (not postgres with options=reference)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_ACTUAL_DB_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres
SUPABASE_POOLER_HOST=aws-1-ap-northeast-1.pooler.supabase.com

# Production: disable seed fallbacks — content comes only from Supabase
MAJALIS_PRODUCTION_CONTENT=1
VITE_MAJALIS_PRODUCTION_CONTENT=1

# Cron (Vercel — يحمي /api/cron/* — server-only)
CRON_SECRET=replace-with-long-random-string
ADMIN_API_SECRET=replace-with-long-random-string

# Upstash Redis — rate limiting في Serverless (server-only)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# OpenAI (خادم — تحليل المحتوى المستورد تلقائياً)
OPENAI_API_KEY=sk-...

# Claude API (خادم فقط — /api/assistant و /api/transcribe)
ANTHROPIC_API_KEY=sk-ant-...

# Vision fallback — استيراد صور الدروس (Claude → OpenAI → OCR → مراجعة يدوية)
VISION_PRIMARY_PROVIDER=anthropic
VISION_FALLBACK_ENABLED=true
LOCAL_OCR_ENABLED=false

# Instagram Graph API (Phase 7 — أتمتة مصادر Instagram)
INSTAGRAM_GRAPH_ACCESS_TOKEN=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# الخادم
PORT=24216
BASE_PATH=/

# ── Cron Auth — طرق المصادقة المدعومة ──
# 1. x-vercel-cron: 1 (Vercel Cron تلقائياً)
# 2. Authorization: Bearer <CRON_SECRET>
# 3. x-cron-secret: <CRON_SECRET>

# ── ملاحظات ──
# • نفّذ supabase/auto_engine_production_complete.sql أو استدعِ /api/cron/apply-migrations
# • المشروع Vite + React — استخدم VITE_ بدل NEXT_PUBLIC_
