# ── المجلس العلمي — متغيرات البيئة (Vite + Express) ──
# انسخ إلى .env.local واملأ القيم الفعلية

# Supabase (عام — يُستخدم في المتصفح)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Supabase (خادم فقط — لا تضف VITE_ لهذا المفتاح)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Claude API (خادم فقط — /api/assistant و /api/transcribe)
ANTHROPIC_API_KEY=sk-ant-...

# الخادم
PORT=24216
BASE_PATH=/

# ── ملاحظات ──
# • المشروع Vite + React (وليس Next.js) — استخدم VITE_ بدل NEXT_PUBLIC_
# • نشر الإنتاج عبر Replit/Node (node artifacts/majalis/server/index.mjs)
# • نفّذ ملفات SQL في supabase/ قبل تفعيل التفريغ والإشعارات
