{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/cron/auto-knowledge-sync.js": {
      "maxDuration": 60,
      "includeFiles": "supabase/**"
    },
    "api/cron/knowledge-sync.js": {
      "maxDuration": 60,
      "includeFiles": "supabase/**"
    },
    "api/cron/sync-data.js": {
      "maxDuration": 60,
      "includeFiles": "supabase/**"
    },
    "api/cron/bootstrap-database.js": {
      "maxDuration": 60,
      "includeFiles": "supabase/**"
    },
    "api/**/*.js": {
      "maxDuration": 30,
      "includeFiles": "supabase/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-data",
      "schedule": "5 21 * * *"
    },
    {
      "path": "/api/cron/sync-fiqh-council",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/knowledge-sync",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/auto-knowledge-sync",
      "schedule": "30 */6 * * *"
    },
    {
      "path": "/api/cron/auto-content-sync",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/auto-content-health",
      "schedule": "15 */6 * * *"
    },
    {
      "path": "/api/cron/system-health",
      "schedule": "45 */6 * * *"
    },
    {
      "path": "/api/cron/connector-health",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/bootstrap-database",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/apply-migrations",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/check-fiqh-links",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/scholarly-verification",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/autonomous-orchestrator",
      "schedule": "15 */6 * * *"
    },
    {
      "path": "/api/cron/global-reference-review",
      "schedule": "0 9 * * 0"
    },
    {
      "path": "/api/cron/islamic-intelligence",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/governance-backup",
      "schedule": "0 4 * * 0"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
