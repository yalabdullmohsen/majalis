{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-data",
      "schedule": "5 21 * * *"
    },
    {
      "path": "/api/cron/sync-fiqh-council",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/knowledge-sync",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/auto-content-sync",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/cron/check-fiqh-links",
      "schedule": "0 7 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
