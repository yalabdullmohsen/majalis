{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "corepack enable && cd ../.. && corepack pnpm install --frozen-lockfile --prod=false",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "{lib/**,supabase/**,data/**,public/data/rulings-encyclopedia/**,dist/index.html}"
    }
  },
