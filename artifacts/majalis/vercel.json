{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "{lib/**,supabase/**,data/**,public/data/rulings-encyclopedia/**}"
    }
  },
  "crons": [
    {
      "path": "/api/cron/process-import-jobs",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/sync-data",
      "schedule": "5 21 * * *"
    },
    {
      "path": "/api/cron/sync-fiqh-council",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/knowledge-sync",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/auto-knowledge-sync",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/auto-content-sync",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/auto-content-health",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/system-health",
      "schedule": "45 3 * * *"
    },
    {
      "path": "/api/cron/connector-health",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/platform-bootstrap",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/cron/bootstrap-database",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/import-phase2-trial",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/apply-migrations",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/check-fiqh-links",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/scholarly-verification",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/autonomous-orchestrator",
      "schedule": "15 8 * * *"
    },
    {
      "path": "/api/cron/global-reference-review",
      "schedule": "0 9 * * 0"
    },
    {
      "path": "/api/cron/islamic-intelligence",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/governance-backup",
      "schedule": "10 4 * * 0"
    },
    {
      "path": "/api/cron/ai-agents",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/verified-knowledge",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/source-monitor",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/lesson-intelligence",
      "schedule": "15,45 * * * *"
    },
    {
      "path": "/api/cron/monitor-sources",
      "schedule": "10 6 * * *"
    },
    {
      "path": "/api/cron/lesson-source-monitor",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/telegram-processor",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/majlis-knowledge-engine",
      "schedule": "5 * * * *"
    },
    {
      "path": "/api/cron/content-scheduler",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/knowledge-reasoning",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-fetch",
      "schedule": "20 * * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-validate",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-questions",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-benefits",
      "schedule": "30 */6 * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-reindex",
      "schedule": "10 2 * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-audit",
      "schedule": "20 4 * * 0"
    },
    {
      "path": "/api/cron/autonomous-platform-cleanup",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/cron/autonomous-platform-bootstrap",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-monitor",
      "schedule": "10,40 * * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-recovery",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/content-scoring",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/universities-review",
      "schedule": "0 2 * * 1"
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/feed.xml",
      "destination": "/api/feed"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon.png"
    },
    {
      "source": "/((?!api/|assets/|feed.xml|sitemap.xml|favicon.ico|favicon.png|robots.txt|version.json).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/version.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/logo.png",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/logo-icon.png",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/favicon.png",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/site.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/opengraph.jpg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(logo\\.png|logo-icon\\.png|favicon\\.png|favicon\\.svg|opengraph\\.jpg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(manifest\\.webmanifest|site\\.webmanifest|robots\\.txt)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}