{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "{lib/**,supabase/**,data/**,public/data/rulings-encyclopedia/**}"
    }
  },
  "crons": [
    {
      "path": "/api/cron/process-import-jobs",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/sync-data",
      "schedule": "5 21 * * *"
    },
    {
      "path": "/api/cron/sync-fiqh-council",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/knowledge-sync",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/auto-knowledge-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/ake-queue-drain",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/auto-content-sync",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/auto-content-health",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/system-health",
      "schedule": "45 3 * * *"
    },
    {
      "path": "/api/cron/cd-post-deploy",
      "schedule": "50 3 * * *"
    },
    {
      "path": "/api/cron/connector-health",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/platform-bootstrap",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/cron/bootstrap-database",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/import-phase2-trial",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron/apply-migrations",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/check-fiqh-links",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/scholarly-verification",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/autonomous-orchestrator",
      "schedule": "15 8 * * *"
    },
    {
      "path": "/api/cron/global-reference-review",
      "schedule": "0 9 * * 0"
    },
    {
      "path": "/api/cron/islamic-intelligence",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/governance-backup",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/ai-agents",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/verified-knowledge",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/source-monitor",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/lesson-intelligence",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/monitor-sources",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/majlis-knowledge-engine",
      "schedule": "5,35 * * * *"
    },
    {
      "path": "/api/cron/content-scheduler",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/knowledge-reasoning",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-fetch",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-validate",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-questions",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-benefits",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-reindex",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-audit",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/autonomous-platform-cleanup",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/cron/autonomous-platform-bootstrap",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-v3",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-v3-health",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-v3-goals",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-v3-analytics",
      "schedule": "15 0 * * *"
    },
    {
      "path": "/api/cron/autonomous-platform-v3-backup",
      "schedule": "0 4 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/feed.xml",
      "destination": "/api/feed"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon.png"
    },
    {
      "source": "/((?!api/|assets/|feed.xml|sitemap.xml|favicon.ico|favicon.png|robots.txt).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
